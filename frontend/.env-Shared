# Insurance AI Platform - Frontend Environment Variables

# API Configuration - THIS SHOULD POINT TO YOUR BACKEND TUNNEL
REACT_APP_API_BASE_URL=https://crown-eur-qualified-adrian.trycloudflare.com/api
REACT_APP_API_TIMEOUT=30000

# Application Configuration
REACT_APP_NAME=Insurance AI Platform
REACT_APP_VERSION=1.0.0

# Feature Flags (for development)
REACT_APP_ENABLE_LOGGING=true
REACT_APP_ENABLE_MOCK_DATA=false

# Pagination Defaults
REACT_APP_DEFAULT_PAGE_SIZE=20

# JWT Token Configuration
REACT_APP_TOKEN_STORAGE_KEY=insurance_ai_token
REACT_APP_REFRESH_TOKEN_KEY=insurance_ai_refresh_token